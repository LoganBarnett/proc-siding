#!/usr/bin/env python3
# Stress the Metal GPU with sustained fp32 matrix multiplications via MLX.
# Run directly (requires mlx available to python3) or via the Nix derivation.
import mlx.core as mx

SIZE = 4096
ITERATIONS = 200

print(f"Stressing Metal GPU: {ITERATIONS} × {SIZE}×{SIZE} fp32 matmul")

a = mx.random.normal([SIZE, SIZE])
mx.eval(a)

for i in range(ITERATIONS):
    a = mx.matmul(a, a)
    if (i + 1) % 20 == 0:
        mx.eval(a)
        print(f"  {i + 1}/{ITERATIONS}")

mx.eval(a)
print("Done.")
